{
  "version": 3,
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "pnpm --filter @workspace/medrise build",
  "builds": [
    {
      "src": "artifacts/medrise/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist/public"
      }
    }
  ]
}
